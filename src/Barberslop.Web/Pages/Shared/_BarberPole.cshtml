<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 100 100" class="barber-pole-icon">
    <defs>
        <pattern id="barberStripes" patternUnits="userSpaceOnUse" width="20" height="20" patternTransform="rotate(45)">
            <rect width="10" height="20" fill="#8B1A1A"/>
            <rect x="10" width="5" height="20" fill="#FFFFFF"/>
            <rect x="15" width="5" height="20" fill="#1A2744"/>
        </pattern>
        <clipPath id="poleClip">
            <rect x="30" y="10" width="40" height="80" rx="20"/>
        </clipPath>
    </defs>
    <rect x="30" y="10" width="40" height="80" rx="20" fill="#FFF5E1" stroke="#1A2744" stroke-width="2"/>
    <g clip-path="url(#poleClip)">
        <rect x="30" y="10" width="40" height="80" fill="url(#barberStripes)" class="barber-stripes"/>
    </g>
    <rect x="25" y="5" width="50" height="8" rx="4" fill="#C0C0C0" stroke="#1A2744" stroke-width="1"/>
    <rect x="25" y="87" width="50" height="8" rx="4" fill="#C0C0C0" stroke="#1A2744" stroke-width="1"/>
    <style>
        .barber-stripes {
            animation: barberSpin 3s linear infinite;
        }
        @@keyframes barberSpin {
            from { transform: translateY(0); }
            to { transform: translateY(-20px); }
        }
        @@media (prefers-reduced-motion: reduce) {
            .barber-stripes { animation: none; }
        }
    </style>
</svg>
