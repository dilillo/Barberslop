<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Barberslop</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YcnS/1WMi+mJLCgOuMsKDAEnTKPxzIbrAEMO" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/barberslop.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-barber-navy">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <partial name="Shared/_BarberPole" />
                <span class="ms-2 fw-bold">Barberslop</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Index">Home</a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (User.IsInRole("Client"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Invitation/Discover">Find Barbers</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Booking/Book">Book Appointment</a>
                            </li>
                        }
                        @if (User.IsInRole("Barber"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Invitation/Pending">Pending Requests</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Invitation/Clients">My Clients</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Schedule/Availability">Schedule</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Services/Index">Services</a>
                            </li>
                        }
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <span class="nav-link text-light">@User.Identity.Name</span>
                        </li>
                        <li class="nav-item">
                            <form asp-page="/Account/Logout" method="post" class="d-inline">
                                <button type="submit" class="nav-link btn btn-link">Logout</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Account/Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Account/Register">Register</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        @RenderBody()
    </main>

    <footer class="container text-center mt-5 mb-3">
        <hr />
        <p class="text-muted">&copy; @DateTime.Now.Year Barberslop. All rights reserved.</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
