@page
@model Barberslop.Web.Pages.Booking.CancelModel
@{
    ViewData["Title"] = "Cancel Appointment";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Cancel Appointment</h5>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }
                <form method="post">
                    <input type="hidden" asp-for="AppointmentId" />
                    <div class="mb-3">
                        <label asp-for="CancellationReason" class="form-label">Reason (optional)</label>
                        <textarea asp-for="CancellationReason" class="form-control" rows="3" maxlength="300"></textarea>
                    </div>
                    <button type="submit" class="btn btn-danger">Confirm Cancellation</button>
                    <a asp-page="/Index" class="btn btn-secondary ms-2">Go Back</a>
                </form>
            </div>
        </div>
    </div>
</div>
