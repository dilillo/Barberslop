@page
@model Barberslop.Web.Pages.Invitation.ClientsModel
@{
    ViewData["Title"] = "My Clients";
}

<h2>Active Clients</h2>

@if (Model.ActiveClients.Count == 0)
{
    <p class="text-muted">No active clients yet.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Since</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var client in Model.ActiveClients)
                {
                    <tr>
                        <td>@client.DisplayName</td>
                        <td>@client.Email</td>
                        <td>@client.Phone</td>
                        <td>@client.AcceptedAt.ToLocalTime().ToString("d")</td>
                        <td>
                            <a asp-page="/Booking/Book" asp-route-barberProfileId="@Model.BarberProfileId"
                               class="btn btn-barber btn-sm">Book for Client</a>
                            <form method="post" asp-page-handler="Disinvite" class="d-inline">
                                <input type="hidden" name="InvitationRequestId" value="@client.InvitationId" />
                                <input type="hidden" name="Reason" value="Other" />
                                <button type="submit" class="btn btn-outline-danger btn-sm">Disinvite</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
